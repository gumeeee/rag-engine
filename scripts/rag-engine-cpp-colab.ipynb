  "cells": [
    {
      "cell_type": "markdown",
      "source": [
        "# RAG Engine - C++ Build & Test\n",
        "\n",
        "This notebook builds and tests the full C++ implementation of the RAG Engine on GPU.\n",
        "\n",
        "**IMPORTANT:**\n",
        "1. Runtime > Change runtime type > **T4 GPU**\n",
        "2. Runtime > Restart runtime (important!)\n",
        "3. Run all cells in order\n",
        "\n",
        "**Expected build time:** ~15-25 minutes\n",
        "\n",
        "**Troubleshooting:** If build fails, check the error messages and see Section 9."
      ],
      "metadata": {
        "id": "header"
      }
    },
    {
      "cell_type": "markdown",
      "source": [
        "## 0. Setup"
      ],
      "metadata": {
        "id": "setup-header"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "# Setup: Define constants and helpers\n",
        "import os\n",
        "import subprocess\n",
        "\n",
        "PROJECT_DIR = '/content/rag-engine'\n",
        "VCPKG_DIR = '/content/vcpkg'\n",
        "\n",
        "def run_cmd(cmd, timeout=600, show_output=True):\n",
        "    \"\"\"Run command in project directory\"\"\"\n",
        "    full_cmd = f'cd {PROJECT_DIR} && {cmd}'\n",
        "    print(f'Running: {cmd[:80]}...' if len(cmd) > 80 else f'Running: {cmd}')\n",
        "    result = subprocess.run(\n",
        "        full_cmd, \n",
        "        shell=True, \n",
        "        capture_output=True, \n",
        "        text=True,\n",
        "        timeout=timeout\n",
        "    )\n",
        "    if show_output:\n",
        "        if result.stdout:\n",
        "            print(result.stdout[-2000:] if len(result.stdout) > 2000 else result.stdout)\n",
        "        if result.returncode != 0 and result.stderr:\n",
        "            print('STDERR:', result.stderr[-1000:] if len(result.stderr) > 1000 else result.stderr)\n",
        "    return result\n",
        "\n",
        "def check_gpu():\n",
        "    import torch\n",
        "    print(f'PyTorch: {torch.__version__}')\n",
        "    print(f'CUDA available: {torch.cuda.is_available()}')\n",
        "    if torch.cuda.is_available():\n",
        "        print(f'GPU: {torch.cuda.get_device_name(0)}')\n",
        "        print(f'CUDA: {torch.version.cuda}')\n",
        "    return torch.cuda.is_available()\n",
        "\n",
        "print('Setup complete')"
      ],
      "execution_count": null,
      "outputs": [],
      "metadata": {
        "id": "setup"
      }
    },
    {
      "cell_type": "markdown",
      "source": [
        "## 1. GPU Verification"
      ],
      "metadata": {
        "id": "gpu-header"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "# Check GPU availability\n",
        "has_gpu = check_gpu()\n",
        "print()\n",
        "if has_gpu:\n",
        "    print('GPU Ready!')\n",
        "else:\n",
        "    print('WARNING: No GPU detected. CPU-only mode will be used.')"
      ],
      "execution_count": null,
      "outputs": [],
      "metadata": {
        "id": "gpu-check"
      }
    },
    {
      "cell_type": "markdown",
      "source": [
        "## 2. Install System Dependencies"
      ],
      "metadata": {
        "id": "apt-header"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "# Install system dependencies\n",
        "print('Installing system packages...')\n",
        "result = subprocess.run(\n",
        "    'apt-get update -qq && apt-get install -y -qq cmake build-essential git curl wget unzip \\\n",
        "    libprotobuf-dev protobuf-compiler libuv1-dev libgoogle-glog-dev g++ ninja-build \\\n",
        "    libomp-dev', \n",
        "    shell=True, \n",
        "    capture_output=True, \n",
        "    text=True,\n",
        "    timeout=300\n",
        ")\n",
        "if result.returncode == 0:\n",
        "    print('System packages installed!')\n",
        "else:\n",
        "    print('Error installing packages:', result.stderr[-500:])"
      ],
      "execution_count": null,
      "outputs": [],
      "metadata": {
        "id": "apt-install"
      }
    },
    {
      "cell_type": "markdown",
      "source": [
        "## 3. Clone Repository"
      ],
      "metadata": {
        "id": "clone-header"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "# Clone repository and setup directories\n",
        "os.chdir('/content')\n",
        "!rm -rf rag-engine\n",
        "!git clone https://github.com/gumeeee/rag-engine.git 2>&1 | tail -3\n",
        "\n",
        "os.makedirs(f'{PROJECT_DIR}/data/corpus', exist_ok=True)\n",
        "os.makedirs(f'{PROJECT_DIR}/models', exist_ok=True)\n",
        "os.makedirs(f'{PROJECT_DIR}/build', exist_ok=True)\n",
        "\n",
        "print(f'\\nProject directory: {PROJECT_DIR}')\n",
        "!ls -la $PROJECT_DIR"
      ],
      "execution_count": null,
      "outputs": [],
      "metadata": {
        "id": "clone"
      }
    },
    {
      "cell_type": "markdown",
      "source": [
        "## 4. Install vcpkg"
      ],
      "metadata": {
        "id": "vcpkg-header"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "# Install vcpkg (if not already installed)\n",
        "if not os.path.exists(VCPKG_DIR):\n",
        "    print('Cloning vcpkg...')\n",
        "    !git clone https://github.com/Microsoft/vcpkg.git /content/vcpkg 2>&1 | tail -3\n",
        "\n",
        "print('Bootstrapping vcpkg...')\n",
        "result = subprocess.run(\n",
        "    '/content/vcpkg/bootstrap-vcpkg.sh',\n",
        "    shell=True,\n",
        "    capture_output=True,\n",
        "    text=True,\n",
        "    timeout=300\n",
        ")\n",
        "if result.returncode == 0:\n",
        "    print('vcpkg bootstrapped successfully!')\n",
        "else:\n",
        "    print('vcpkg bootstrap failed:', result.stderr[-500:])"
      ],
      "execution_count": null,
      "outputs": [],
      "metadata": {
        "id": "vcpkg-install"
      }
    },
    {
      "cell_type": "markdown",
      "source": [
        "## 5. Install C++ Dependencies"
      ],
      "metadata": {
        "id": "deps-header"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "# Install dependencies via vcpkg\n",
        "# Using CPU versions for simpler build (GPU versions available but more complex)\n",
        "\n",
        "deps = 'faiss-cpu onnxruntime libuv protobuf spdlog nlohmann-json'\n",
        "\n",
        "print(f'Installing: {deps}')\n",
        "print('This may take 10-15 minutes...')\n",
        "\n",
        "result = subprocess.run(\n",
        f'export VCPKG_ROOT=/content/vcpkg && /content/vcpkg/vcpkg install {deps} --triplet x64-linux',\n",
        "    shell=True,\n",
        "    capture_output=True,\n",
        "    text=True,\n",
        "    timeout=1800  # 30 minutes\n",
        ")\n",
        "\n",
        "print('\\n--- Last 50 lines ---')\n",
        "lines = result.stdout.split('\\n')\n",
        "for line in lines[-50:]:\n",
        "    print(line)\n",
        "\n",
        "if result.returncode == 0:\n",
        "    print('\\nDependencies installed successfully!')\n",
        "else:\n",
        "    print('\\nWarning: Some dependencies may have failed')\n",
        "    print(result.stderr[-1000:] if result.stderr else '')"
      ],
      "execution_count": null,
      "outputs": [],
      "metadata": {
        "id": "deps-install"
      }
    },
    {
      "cell_type": "markdown",
      "source": [
        "## 6. Generate Sample Corpus"
      ],
      "metadata": {
        "id": "corpus-header"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "# Create sample corpus\n",
        "import os\n",
        "\n",
        "corpus_dir = f'{PROJECT_DIR}/data/corpus'\n",
        "os.makedirs(corpus_dir, exist_ok=True)\n",
        "\n",
        "documents = {\n",
        "    'transformer.txt': '''\n",
        "    The Transformer architecture was introduced in 2017. It uses self-attention\n",
        "    mechanisms to process input sequences in parallel. Key components include\n",
        "    positional encodings, multi-head attention, and feed-forward layers.\n",
        "    ''',\n",
        "    'bert.txt': '''\n",
        "    BERT uses bidirectional transformers for language understanding. It processes\n",
        "    text in both directions simultaneously. Pre-training uses masked language\n",
        "    modeling and next sentence prediction.\n",
        "    ''',\n",
        "    'gpt.txt': '''\n",
        "    GPT is an autoregressive language model by OpenAI. It uses transformer\n",
        "    decoder blocks trained using next-token prediction. GPT-3 has 175B parameters.\n",
        "    ''',\n",
        "    'rag.txt': '''\n",
        "    Retrieval-Augmented Generation combines language models with knowledge retrieval.\n",
        "    Documents are retrieved from a vector database and provided as context.\n",
        "    ''',\n",
        "    'vector_search.txt': '''\n",
        "    Vector similarity search uses embeddings to find semantically similar items.\n",
        "    FAISS provides efficient algorithms for billion-scale similarity search.\n",
        "    '''\n",
        "}\n",
        "\n",
        "for filename, content in documents.items():\n",
        "    with open(f'{corpus_dir}/{filename}', 'w') as f:\n",
        "        f.write(content.strip())\n",
        "\n",
        "print(f'Created {len(documents)} documents')"
      ],
      "execution_count": null,
      "outputs": [],
      "metadata": {
        "id": "create-corpus"
      }
    },
    {
      "cell_type": "markdown",
      "source": [
        "## 7. Generate Embeddings (Python)"
      ],
      "metadata": {
        "id": "embeddings-header"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "# Generate embeddings using Python (will be used by C++)\n",
        "!pip install sentence-transformers -q\n",
        "\n",
        "from sentence_transformers import SentenceTransformer\n",
        "import numpy as np\n",
        "\n",
        "print('Loading model...')\n",
        "model = SentenceTransformer('sentence-transformers/all-MiniLM-L6-v2')\n",
        "\n",
        "# Load and embed documents\n",
        "import glob\n",
        "doc_files = sorted(glob.glob(f'{corpus_dir}/*.txt'))\n",
        "texts = []\n",
        "for f in doc_files:\n",
        "    with open(f) as fp:\n",
        "        texts.append(fp.read())\n",
        "\n",
        "print('Generating embeddings...')\n",
        "embeddings = model.encode(texts, convert_to_numpy=True)\n",
        "\n",
        "# Save in binary format for C++\n",
        "output_file = f'{PROJECT_DIR}/data/corpus.corpus'\n",
        "count = len(texts)\n",
        "dim = embeddings.shape[1]\n",
        "\n",
        "with open(output_file, 'wb') as f:\n",
        "    f.write(count.to_bytes(4, 'little'))\n",
        "    f.write(dim.to_bytes(4, 'little'))\n",
        "    embeddings.astype(np.float32).tofile(f)\n",
        "\n",
        "print(f'Saved {count} embeddings of dim={dim} to {output_file}')\n",
        "print(f'File size: {os.path.getsize(output_file)} bytes')"
      ],
      "execution_count": null,
      "outputs": [],
      "metadata": {
        "id": "generate-embeddings"
      }
    },
    {
      "cell_type": "markdown",
      "source": [
        "## 8. Build C++ Project"
      ],
      "metadata": {
        "id": "build-header"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "# Configure CMake\n",
        "import os\n",
        "\n",
        "os.chdir(f'{PROJECT_DIR}/build')\n",
        "os.environ['VCPKG_ROOT'] = VCPKG_DIR\n",
        "\n",
        "cmake_cmd = '''\n",
        "cmake .. \\\n",
        "    -DCMAKE_BUILD_TYPE=Release \\\n",
        "    -DCMAKE_TOOLCHAIN_FILE=/content/vcpkg/scripts/buildsystems/vcpkg.cmake \\\n",
        "    -DVCPKG_TARGET_TRIPLET=x64-linux \\\n",
        "    -DCUDA_USE_STATIC_CUDA_RUNTIME=OFF\n",
        "'''.strip()\n",
        "\n",
        "print('Configuring CMake...')\n",
        "result = subprocess.run(\n",
        "    cmake_cmd,\n",
        "    shell=True,\n",
        "    capture_output=True,\n",
        "    text=True,\n",
        "    cwd=f'{PROJECT_DIR}/build',\n",
        "    timeout=300\n",
        ")\n",
        "\n",
        "print(result.stdout[-3000:] if len(result.stdout) > 3000 else result.stdout)\n",
        "if result.returncode != 0:\n",
        "    print('\\nCMake errors:')\n",
        "    print(result.stderr[-2000:] if result.stderr else '')"
      ],
      "execution_count": null,
      "outputs": [],
      "metadata": {
        "id": "cmake-configure"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "# Build project\n",
        "print('Building project...')\n",
        "print('This may take 5-10 minutes...')\n",
        "\n",
        "result = subprocess.run(\n",
        "    'cmake --build . --config Release -j$(nproc) 2>&1',\n",
        "    shell=True,\n",
        "    capture_output=True,\n",
        "    text=True,\n",
        "    cwd=f'{PROJECT_DIR}/build',\n",
        "    timeout=1800\n",
        ")\n",
        "\n",
        "if result.returncode == 0:\n",
        "    print('\\n=== BUILD SUCCEEDED ===')\n",
        "    # Show last lines for success\n",
        "    lines = result.stdout.split('\\n')\n",
        "    for line in lines[-20:]:\n",
        "        print(line)\n",
        "else:\n",
        "    print('\\n=== BUILD FAILED ===')\n",
        "    print(result.stdout[-3000:] if result.stdout else '')\n",
        "    print('\\nErrors:')\n",
        "    print(result.stderr[-2000:] if result.stderr else '')"
      ],
      "execution_count": null,
      "outputs": [],
      "metadata": {
        "id": "cmake-build"
      }
    },
    {
      "cell_type": "markdown",
      "source": [
